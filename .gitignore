# Learner data is private — keep the folder, ignore its contents.
/tracks/*
!/tracks/.gitkeep

# Personal learner profile (copy from profile.example.md).
profile.md

# registry.json is a rebuildable cache of the user's personal tracks
# (regenerate with `python3 scripts/registry.py rebuild`). Keep it out of the
# clean, data-free product repo so track ids don't leak.
/registry.json

# Python bytecode / caches.
__pycache__/
*.pyc

# Backups (engine writes *.bak / review-state backups).
*.bak
*.bak.*

# Atomic-write temp files (tmp+os.replace) and quarantined corrupt state.
*.tmp
*.bad.*

# OS cruft.
.DS_Store

# Obsidian vault runtime — created when this folder is opened as a vault. Huge
# (bundles plugin binaries) and may contain auth tokens. NEVER ship.
.obsidian/

# Claudian plugin runtime + settings — its settings file holds the auth token. NEVER ship.
.claudian/

# Claude Code in-vault runtime; ship ONLY the discoverable skill symlink, nothing else.
.claude/*
!.claude/skills/

# Personalized FSRS weights (fit from a learner's review history — personal data).
# Per-track weights under tracks/ are already covered above; this is the global fit.
/fsrs-weights.json
